{
  "name": "misra-web-testing-platform",
  "version": "1.0.0",
  "description": "AI-powered SaaS platform for MISRA compliance analysis and UI regression testing",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "dev": "npm run dev --workspaces",
    "deploy": "npm run deploy --workspaces",
    "test:e2e": "npx playwright test",
    "test:e2e:quick": "npx playwright test -g \"Quick Verification\"",
    "test:e2e:full": "npx playwright test -g \"Complete MISRA Analysis\"",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:report": "npx playwright show-report",
    "test:hybrid": "cd packages/backend && npx playwright test --grep \"Complete Hybrid Workflow\" --headed",
    "test:hybrid:debug": "cd packages/backend && npx playwright test --grep \"Complete Hybrid Workflow\" --headed --debug",
    "test:complete": "cd packages/backend && npx playwright test complete-hybrid-workflow.spec.ts --headed",
    "hybrid": "node hybrid-server.js",
    "start": "node hybrid-server.js",
    "kill-port": "kill-port-3000.bat",
    "clean-start": "npm run kill-port && npm run hybrid"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.130.0",
    "aws-cdk-lib": "^2.130.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "imapflow": "^1.3.2",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "axios": "^1.6.0",
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
