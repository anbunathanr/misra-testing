# E2E Automation Test Configuration
# Copy this file to .env.test and fill in your values

# Test Account Credentials
TEST_EMAIL=your-test-email@gmail.com
TEST_PASSWORD=your-test-password

# Gmail IMAP Configuration (for automatic OTP extraction)
# Get App Password from: https://myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-test-email@gmail.com
IMAP_PASS=your-16-character-app-password

# Target URL
BASE_URL=https://misra.digitransolutions.in

# Optional: Playwright Configuration
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=1000
