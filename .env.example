# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# Environment
NODE_ENV=development
ENVIRONMENT=local

# API Configuration
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# n8n Configuration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
N8N_API_KEY=your-n8n-api-key

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database Configuration (for local development)
DYNAMODB_ENDPOINT=http://localhost:8000

# S3 Configuration (for local development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Testing Configuration
PLAYWRIGHT_BROWSERS=chromium,firefox,webkit
TEST_TIMEOUT=30000

# AI Test Generation Configuration
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# AI Usage Limits
USER_MONTHLY_COST_LIMIT=100
USER_DAILY_CALL_LIMIT=100
PROJECT_MONTHLY_COST_LIMIT=50
PROJECT_DAILY_CALL_LIMIT=50

# AI Retry Configuration
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_INITIAL_DELAY_MS=1000
AI_RETRY_MAX_DELAY_MS=4000
AI_RETRY_BACKOFF_MULTIPLIER=2

# AI Timeout Configuration
AI_ANALYSIS_TIMEOUT_MS=30000
AI_GENERATION_TIMEOUT_MS=60000
AI_BATCH_TIMEOUT_MS=300000

# AI Batch Processing Configuration
AI_BATCH_MAX_CONCURRENCY=3
AI_BATCH_MAX_SCENARIOS=20
